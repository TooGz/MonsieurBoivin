{
  "ci": {
    "collect": {
      "staticDistDir": "./public",
      "url": [
        "/",
        "/posts/",
        "/recettes/",
        "/atelier/grenouille/"
      ],
      "numberOfRuns": 1,
      "settings": {
        "chromeFlags": "--headless=new"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.75
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:best-practices": [
          "warn",
          {
            "minScore": 0.85
          }
        ],
        "categories:seo": [
          "error",
          {
            "minScore": 0.9
          }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
